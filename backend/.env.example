# MedGraph MVP backend settings
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
ENABLE_BACKEND_ACCESS_CONTROL=false

# Local open-source Cognee adapter.
COGNEE_ENABLE_SDK=false
COGNEE_RESET_ON_START=false
COGNEE_LOCAL_OPERATION_TIMEOUT=12

# Cognee Cloud adapter for shared non-sensitive protocol memory.
COGNEE_ENABLE_CLOUD=false
COGNEE_CLOUD_API_KEY=
COGNEE_CLOUD_BASE_URL=https://api.cognee.ai
COGNEE_CLOUD_CONNECT_TIMEOUT=20
COGNEE_CLOUD_OPERATION_TIMEOUT=20

# LLM/embedding settings used by Cognee when SDK mode is enabled.
LLM_API_KEY=
LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-max
EMBEDDING_API_KEY=
EMBEDDING_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v3
